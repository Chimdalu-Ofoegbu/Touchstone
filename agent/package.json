{
  "name": "@touchstone/agent",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./hash": "./src/hash.ts",
    "./schema": "./src/schema.ts",
    "./constants/grade-enum": "./src/constants/grade-enum.ts"
  },
  "scripts": {
    "rate": "tsx --env-file-if-exists=../.env src/cli.ts",
    "mint-identity": "tsx --env-file-if-exists=../.env src/mint-identity.ts",
    "publish-rating": "tsx --env-file-if-exists=../.env src/publish-cli.ts",
    "watch": "tsx --env-file-if-exists=../.env src/watch.ts",
    "capture-elixir": "tsx src/fixtures/capture-elixir.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "RUN_LIVE=1 vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "canonicalize": "^3.0.0",
    "pinata": "^2.5.6",
    "viem": "^2.52.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
