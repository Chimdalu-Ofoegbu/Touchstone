# Touchstone deployer secrets — copy to .env (gitignored) and fill in.
# DO NOT commit a populated .env file.

# Hex private key for the deployer wallet (0x...). Fund via https://faucet.sepolia.mantle.xyz/ for Sepolia.
PRIVATE_KEY=

# Mantle Sepolia RPC (default public endpoint is fine for iteration).
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz

# Mantle Mainnet RPC (used on Day 5 — leave empty for Phase 1).
MANTLE_RPC_URL=https://rpc.mantle.xyz

# Optional: Etherscan/Blockscout key. Blockscout does NOT require one.
MANTLE_EXPLORER_KEY=

# Phase 3 — minted ERC-8004 agent token id (set after running pnpm mint-identity, Plan 03)
AGENT_TOKEN_ID=
# Phase 3 — RatingRegistry address after the once-only Mainnet redeploy (Plan 03)
RATING_REGISTRY_ADDRESS=
# Phase 3 — IPFS pin (Pinata, the single LOCKED provider; raw-file CID). Required before publish/watch.
PINATA_JWT=
# Optional dedicated Pinata gateway (public gateway works if unset)
PINATA_GATEWAY=
