# Foundry (root-anchored so it does not also match agent/out/ — see the
# historical-proof exception further down)
/out/
/cache/
/broadcast/

# Node / TypeScript engine (Phase 2 agent/)
node_modules/
# Ignore regenerable live rating JSON under agent/out/, but NOT the directory itself,
# so the curated historical-proof artifact below can be re-included.
agent/out/*
# Exception: the historical-proof artifact is a committed Phase-4 deliverable (REQ-06, D-04).
!agent/out/historical/
agent/dist/
agent/.test-out/

# Secrets (per WR-04: cover .env.* family, e.g., .env.mantle / .env.production)
.env
.env.*
!.env.example
*.pem
*.key

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Claude Code per-session local state (keep launch.json, drop worktrees)
.claude/worktrees/
